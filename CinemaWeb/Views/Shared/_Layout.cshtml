<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - SF Cinema</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <style>
        body { background-color: #0a0a0a; color: #ffffff; font-family: 'Segoe UI', sans-serif; }
        .navbar { background-color: #111111 !important; border-bottom: 2px solid #e30613; padding: 0.8rem 2rem; }
        .navbar-brand { color: #e30613 !important; font-size: 1.8rem; font-weight: 900; letter-spacing: 2px; }
        .nav-link { color: #ffffff !important; font-weight: 500; margin: 0 0.5rem; transition: color 0.2s; }
        .nav-link:hover { color: #e30613 !important; }
        .btn-danger { background-color: #e30613; border-color: #e30613; }
        .btn-danger:hover { background-color: #c00510; border-color: #c00510; }
        .btn-outline-light:hover { background-color: #e30613; border-color: #e30613; }
        .card { background-color: #1a1a1a; border: 1px solid #2a2a2a; transition: transform 0.2s, box-shadow 0.2s; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(227, 6, 19, 0.3); }
        .card-title { color: #ffffff; font-weight: 700; }
        .card-text { color: #aaaaaa; }
        .badge-genre { background-color: #e30613; color: white; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; }
        .hero { background: linear-gradient(135deg, #1a0000 0%, #0a0a0a 50%, #1a0000 100%); padding: 4rem 2rem; margin-bottom: 3rem; border-bottom: 2px solid #e30613; }
        .hero h1 { font-size: 3rem; font-weight: 900; color: #ffffff; }
        .hero p { color: #aaaaaa; font-size: 1.2rem; }
        .section-title { color: #ffffff; font-weight: 800; font-size: 1.5rem; border-left: 4px solid #e30613; padding-left: 1rem; margin-bottom: 1.5rem; }
        table { color: #ffffff !important; }
        .table { background-color: #1a1a1a; color: #ffffff; }
        .table th { background-color: #e30613; color: white; border: none; }
        .table td { border-color: #2a2a2a; vertical-align: middle; }
        .table tr:hover { background-color: #222222; }
        footer { background-color: #111111; border-top: 2px solid #e30613 !important; color: #aaaaaa; padding: 1.5rem 0; margin-top: 4rem; }
        footer a { color: #e30613; }
        .form-control { background-color: #1a1a1a; border: 1px solid #333; color: #ffffff; }
        .form-control:focus { background-color: #222; border-color: #e30613; color: #ffffff; box-shadow: 0 0 0 0.2rem rgba(227, 6, 19, 0.25); }
        .form-label { color: #aaaaaa; }
        h1, h2, h3 { color: #ffffff; }
        a { color: #e30613; }
        a:hover { color: #ff2233; }
        select.form-control option { background-color: #1a1a1a; }
    </style>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">🎬 SF CINEMA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Hem</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Movie" asp-action="Index">Filmer</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Salong" asp-action="Index">Salonger</a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                    @if (User.IsInRole("User"))
                    {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Booking" asp-action="Index">🎟️ Mina bokningar</a>
                    </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                    <li class="nav-item">
                        <a class="nav-link" style="color:#e30613 !important;" asp-controller="Movie" asp-action="Index">⚙️ Hantera filmer</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" style="color:#e30613 !important;" asp-controller="Admin" asp-action="Index">📊 Översikt</a>
                    </li>
                    }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                    <li class="nav-item">
                        <span class="nav-link" style="color:#aaa;">@User.Identity.Name</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Logout">Logga ut</a>
                    </li>
                    }
                    else
                    {
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" asp-controller="Account" asp-action="Register">Skapa konto</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-danger ms-2" asp-controller="Account" asp-action="Login">Logga in</a>
                    </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<main role="main">
    @RenderBody()
</main>

<footer>
    <div class="container text-center">
        <p>&copy; 2026 SF Cinema &mdash; <a asp-controller="Home" asp-action="Privacy">Integritetspolicy</a></p>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>