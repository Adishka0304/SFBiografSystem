@model CinemaWeb.Models.Movie

@{
    ViewData["Title"] = "Redigera film";
}

<div class="container" style="max-width: 600px; margin-top: 3rem;">
    <div class="card p-4">
        <h2 class="mb-4">✏️ Redigera film</h2>

        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label class="form-label">Titel</label>
                <input asp-for="Title" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Genre</label>
                <input asp-for="Genre" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Längd (minuter)</label>
                <input asp-for="DurationMinutes" type="number" class="form-control" />
            </div>
            <div class="mb-4">
                <label class="form-label">Beskrivning</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Spara ändringar</button>
                <a asp-action="Index" class="btn btn-outline-light">Avbryt</a>
            </div>
        </form>
    </div>
</div>