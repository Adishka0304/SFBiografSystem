@model List<CinemaWeb.Models.Salong>

@{
    ViewData["Title"] = "Salonger";
}

<div class="hero text-center">
    <h1>Våra salonger</h1>
    <p>Upplev film i världsklass</p>
</div>

<div class="container">
    <h2 class="section-title mb-4">Tillgängliga salonger</h2>
    <div class="row g-4">
        @foreach (var salong in Model)
        {
            <div class="col-md-4">
                <div class="card p-4 text-center h-100">
                    <h2>
                        @if (salong.Typ == "IMAX") { <text>🎬</text> }
                        else if (salong.Typ == "3D") { <text>🥽</text> }
                        else { <text>🎭</text> }
                    </h2>
                    <h5 class="card-title mt-2">@salong.Namn</h5>
                    <span class="badge-genre">@salong.Typ</span>
                    <p class="card-text mt-3">💺 @salong.AntalPlatser platser</p>
                </div>
            </div>
        }
    </div>
</div>